{
  "expo": {
    "name": "SpeakRight",
    "slug": "speakright",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "speakright",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F7FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.speakright.app"
    },
    "android": {
      "package": "com.speakright.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#F0F7FF"
      },
      "compileSdkVersion": 36,
      "targetSdkVersion": 35
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access Face ID to authenticate."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "713c9c66-b365-4dac-bbd0-e2746ebbf13d"
      }
    },
    "owner": "mark_condino"
  }
}
